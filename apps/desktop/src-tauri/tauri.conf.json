{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Woom",
  "version": "1.0.0",
  "identifier": "com.woom.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Woom",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#0C1117",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: wss:; frame-ancestors 'none'; base-uri 'self'; object-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": [
      "binaries/woom-github",
      "binaries/woom-jira",
      "binaries/woom-memory",
      "binaries/woom-sentry",
      "binaries/woom-app"
    ],
    "resources": ["../../../docs/*.md"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 Woom",
    "shortDescription": "A focused, warm-lit workspace for software work",
    "longDescription": "Woom is a focused, warm-lit workspace for software work. Tickets, pull requests, errors, agents, code, canvas, terminal — each gets a full window when it has your attention, and they all link together when you need them to.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": null,
      "providerShortName": null,
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://woom.app/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "PLACEHOLDER_REPLACE_WITH_TAURI_SIGNER_OUTPUT"
    }
  }
}
