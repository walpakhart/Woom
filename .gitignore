# Dependencies
node_modules/
target/

# Build outputs
build/
dist/
.svelte-kit/

# Tauri build outputs
**/src-tauri/target/
**/src-tauri/gen/schemas/
apps/desktop/src-tauri/binaries/woom-*
# RTK binary is fetched at build-time by `scripts/fetch-rtk.sh` from the
# upstream rtk-ai/rtk GitHub releases. Pinning the version in the script
# (not via git) keeps the repo small (~7MB per arch × 4 arches).
apps/desktop/src-tauri/binaries/rtk-*

# Env + secrets
.env
.env.local
.env.*.local
*.pem
*.p12

# Tauri updater signing keys — generated locally by the maintainer.
# The real key lives at ~/.tauri/woom-update.key (outside the repo);
# these globs are defence-in-depth so a stray copy in the worktree
# can't accidentally land in a commit. See docs/RELEASES.md.
*.tauri.key
*.tauri.key.pub

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local data
.forge-data/

# Claude Code local state
.claude/
